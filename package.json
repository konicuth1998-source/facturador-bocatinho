{
  "name": "facturador-bocatinho",
  "version": "1.0.0",
  "description": "Facturador de escritorio para Bocatinho Snacks",
  "main": "electron/main.js",
  "author": {
    "name": "Bocatinho Snacks",
    "email": "bocatinhosnacks@gmail.com"
  },
  "homepage": "https://github.com/konicuth1998-source/facturador-bocatinho",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:windows": "electron-builder --win nsis portable --publish never",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bocatinhosnacks.facturador",
    "productName": "Facturador Bocatinho",
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "assets/**/*",
      "build/**/*",
      "electron/**/*",
      "README.txt"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "build/icons",
      "maintainer": "Bocatinho Snacks <bocatinhosnacks@gmail.com>"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName} Setup-${version}-${os}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Facturador Bocatinho"
    },
    "portable": {
      "artifactName": "${productName} Portable-${version}-${os}-${arch}.${ext}"
    }
  }
}
